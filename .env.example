# ============================================
# HARDHAT PRODUCTION CONFIGURATION
# ============================================

# ============================================
# PRIVATE KEYS (NEVER COMMIT REAL KEYS!)
# ============================================
# Your deployer wallet private key (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# Optional: Separate keys for different networks
MAINNET_PRIVATE_KEY=your_mainnet_private_key_here
TESTNET_PRIVATE_KEY=your_testnet_private_key_here

# ============================================
# RPC ENDPOINTS
# ============================================
# Get free RPC URLs from:
# - Alchemy: https://www.alchemy.com/
# - Infura: https://infura.io/
# - QuickNode: https://www.quicknode.com/

# Ethereum Mainnet
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Ethereum Sepolia Testnet (recommended for testing)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Ethereum Goerli Testnet (deprecated but still available)
GOERLI_RPC_URL=https://eth-goerli.g.alchemy.com/v2/YOUR_API_KEY

# Polygon Mainnet
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Polygon Mumbai Testnet
MUMBAI_RPC_URL=https://polygon-mumbai.g.alchemy.com/v2/YOUR_API_KEY

# Arbitrum One
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Optimism
OPTIMISM_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Base
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# ============================================
# BLOCK EXPLORERS API KEYS
# ============================================
# For contract verification
# Get API keys from respective block explorers

# Etherscan (Ethereum Mainnet, Sepolia, Goerli)
# Get from: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Polygonscan (Polygon Mainnet, Mumbai)
# Get from: https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# Arbiscan (Arbitrum)
# Get from: https://arbiscan.io/myapikey
ARBISCAN_API_KEY=your_arbiscan_api_key_here

# Optimistic Etherscan (Optimism)
# Get from: https://optimistic.etherscan.io/myapikey
OPTIMISTIC_ETHERSCAN_API_KEY=your_optimistic_etherscan_api_key_here

# Basescan (Base)
# Get from: https://basescan.org/myapikey
BASESCAN_API_KEY=your_basescan_api_key_here

# ============================================
# GAS REPORTING
# ============================================
# Enable gas reporting in tests
REPORT_GAS=true

# CoinMarketCap API for USD gas prices
# Get from: https://coinmarketcap.com/api/
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key_here

# Output gas report to file
GAS_REPORT_FILE=gas-report.txt

# ============================================
# CONTRACT DEPLOYMENT SETTINGS
# ============================================
# Initial contract owner address (defaults to deployer if not set)
OWNER_ADDRESS=0x0000000000000000000000000000000000000000

# NFT Contract Settings
NFT_NAME=AI-Powered NFT
NFT_SYMBOL=AINFT
NFT_BASE_URI=ipfs://

# Marketplace Settings
MARKETPLACE_FEE_PERCENT=250
MARKETPLACE_FEE_RECIPIENT=0x0000000000000000000000000000000000000000

# Royalty Settings (in basis points, e.g., 500 = 5%)
DEFAULT_ROYALTY_PERCENT=500

# ============================================
# FORKING (for testing against mainnet state)
# ============================================
# Enable mainnet forking
FORK_MAINNET=false

# Block number to fork from (leave empty for latest)
FORK_BLOCK_NUMBER=

# ============================================
# DEPLOYMENT TRACKING
# ============================================
# Deployed contract addresses (auto-populated by scripts)
NFT_CONTRACT_ADDRESS_SEPOLIA=
NFT_CONTRACT_ADDRESS_MAINNET=
MARKETPLACE_CONTRACT_ADDRESS_SEPOLIA=
MARKETPLACE_CONTRACT_ADDRESS_MAINNET=

# ============================================
# SECURITY SETTINGS
# ============================================
# Enable contract size checking
CONTRACT_SIZER=false

# Maximum contract size (24KB = 24576 bytes)
MAX_CONTRACT_SIZE=24576

# ============================================
# TESTING SETTINGS
# ============================================
# Mocha timeout (milliseconds)
MOCHA_TIMEOUT=200000

# Enable parallel testing
PARALLEL_TESTS=false

# ============================================
# MULTISIG SETTINGS (for production)
# ============================================
# Gnosis Safe or multisig wallet address
MULTISIG_ADDRESS=0x0000000000000000000000000000000000000000

# Required signatures
MULTISIG_THRESHOLD=2

# ============================================
# MONITORING & ALERTS
# ============================================
# Tenderly Project (for monitoring)
TENDERLY_PROJECT=
TENDERLY_USERNAME=
TENDERLY_ACCESS_KEY=

# Defender (for automated operations)
DEFENDER_API_KEY=
DEFENDER_API_SECRET=

# ============================================
# IPFS SETTINGS
# ============================================
# IPFS Gateway for metadata
IPFS_GATEWAY=https://ipfs.io/ipfs/

# Pinata API (for pinning)
PINATA_API_KEY=
PINATA_SECRET_KEY=

# ============================================
# NOTES
# ============================================
# 1. NEVER commit your .env file to version control
# 2. Keep your private keys secure and never share them
# 3. Use different wallets for testnet and mainnet
# 4. Consider using a hardware wallet for mainnet deployments
# 5. Always test on testnet before deploying to mainnet
# 6. Use a multisig wallet for production contract ownership
# 7. Enable 2FA on all service accounts (Alchemy, Etherscan, etc.)
