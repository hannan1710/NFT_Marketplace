# Server Configuration
PORT=4000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/trust_scores
MONGODB_TEST_URI=mongodb://localhost:27017/trust_scores_test

# Blockchain Configuration
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
POLYGON_RPC_URL=https://polygon-rpc.com
NFT_CONTRACT_ADDRESS=0x...
MARKETPLACE_CONTRACT_ADDRESS=0x...

# Fraud Detection Service
FRAUD_DETECTOR_URL=http://localhost:8000

# Trust Score Weights (must sum to 1.0)
WEIGHT_TRANSACTIONS=0.25
WEIGHT_DISPUTES=0.20
WEIGHT_ACCOUNT_AGE=0.15
WEIGHT_FRAUD_HISTORY=0.25
WEIGHT_BEHAVIORAL=0.15

# Score Thresholds
TRUST_SCORE_EXCELLENT=80
TRUST_SCORE_GOOD=60
TRUST_SCORE_FAIR=40
TRUST_SCORE_POOR=20

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
