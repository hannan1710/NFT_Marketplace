# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/nft_events
MONGODB_TEST_URI=mongodb://localhost:27017/nft_events_test

# Redis Configuration (for Bull queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Blockchain Configuration
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
ETHEREUM_WS_URL=wss://mainnet.infura.io/ws/v3/YOUR_INFURA_KEY
POLYGON_RPC_URL=https://polygon-rpc.com
NETWORK=ethereum

# Contract Addresses
NFT_CONTRACT_ADDRESS=0x...
MARKETPLACE_CONTRACT_ADDRESS=0x...

# Microservices URLs
PRICE_PREDICTOR_URL=http://localhost:8001
FRAUD_DETECTOR_URL=http://localhost:8000
TRUST_SCORE_URL=http://localhost:4000

# Event Processing
ENABLE_PRICE_PREDICTION=true
ENABLE_FRAUD_DETECTION=true
ENABLE_TRUST_SCORE=true
BATCH_SIZE=10
RETRY_ATTEMPTS=3
RETRY_DELAY=5000

# Sync Configuration
SYNC_FROM_BLOCK=0
SYNC_BATCH_SIZE=1000
ENABLE_HISTORICAL_SYNC=false
